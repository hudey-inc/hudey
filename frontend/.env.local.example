# Hudey Frontend - API URL
# Point to your Railway backend or local: http://localhost:8000
NEXT_PUBLIC_API_URL=https://your-app.up.railway.app

# Sentry Error Tracking (optional - errors logged to console if not set)
# Get your DSN from: sentry.io → Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
